# ============================================
# Backend (обязательно для docker-compose)
# ============================================
# Пример: Postgres на localhost (отдельный compose/инстанс)
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5434/app_db
CORS_ALLOWED_ORIGINS=https://app.musorka.su,musorka://

# ============================================
# PostgreSQL (если поднимаете БД отдельно — справочно)
# ============================================
POSTGRES_DB=bytovoy_pomoshnik
POSTGRES_USER=bp_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================
# SMTP (Email)
# ============================================
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=your-email@yandex.ru
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@yandex.ru
SMTP_SECURE=false

# ============================================
# Mobile client API
# ============================================
# URL API, доступный мобильному приложению:
API_BASE_URL=https://app.musorka.su

# ============================================
# Live feed («До/После»)
# ============================================
# Включает вкладку Live в клиенте для ролей client/executor.
EXPO_PUBLIC_LIVE_ENABLED=true

# ============================================
# Ports
# ============================================
PORT=3000
HTTP_PORT=80
HTTPS_PORT=443
